@page "/weather"
@attribute [StreamRendering]
@rendermode InteractiveServer

<PageTitle>Weather</PageTitle>

<h1>Weather</h1>

<p>This component demonstrates showing data.</p>

@if (forecasts == null)
{
    <p>
        <em>Loading...</em>
    </p>
}
else
{
    <table class="table">
        <thead>
        <tr>
            <th>Date</th>
            <th>Temp. (C)</th>
            <th>Temp. (F)</th>
            <th>Summary</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var forecast in forecasts)
        {
            <tr>
                <td>@forecast.Date.ToShortDateString()</td>
                <td>@forecast.TemperatureC</td>
                <td>@forecast.TemperatureF</td>
                <td>@forecast.Summary</td>
            </tr>
        }
        </tbody>
    </table>

    <div>

        @* liczba dni gdzie temp. > 15 stopni *@
        <p>Count of warm days: @coutOfWarmDays</p>

        <button class="btn btn-primary" @onclick="noWarmDays">
            warm days
        </button>

        <button class="btn btn-secondary" @onclick="RestoreDays">
            restore
        </button>
    </div>
}

@code {
    private WeatherForecast[]? forecasts;
    private WeatherForecast[]? originalForecasts;
    private int coutOfWarmDays;

    protected override async Task OnInitializedAsync()
    {
        // Simulate asynchronous loading to demonstrate streaming rendering
        await Task.Delay(500);

        var startDate = DateOnly.FromDateTime(DateTime.Now);
        var summaries = new[] { "Freezing", "Bracing", "Chilly", "Cool", "Mild", "Warm", "Balmy", "Hot", "Sweltering", "Scorching" };

        forecasts = Enumerable.Range(1, 10).Select(index => new WeatherForecast
        {
            Date = startDate.AddDays(index),
            TemperatureC = Random.Shared.Next(-20, 55),
            Summary = summaries[Random.Shared.Next(summaries.Length)]

        }).ToArray();

        // zapisujemy pierwotną tablicę, żeby można było ją później przywrócić
        originalForecasts = forecasts;

        // zmienna do wyciągnięcia ciepłych dni > 15 stopni
        coutOfWarmDays = forecasts.Count(forecast => forecast.TemperatureC > 15);
    }

    private void noWarmDays()
    {
        if (forecasts == null)
        {
            return;
        }

        // tylko dni z temperaturą >= 15 stopni
        forecasts = forecasts
            .Where(forecast => forecast.TemperatureC >= 15)
            .ToArray();

        // licznik po filtrowaniu
        coutOfWarmDays = forecasts.Count(forecast => forecast.TemperatureC > 15);
    }

    private void RestoreDays()
    {
        if (originalForecasts == null)
        {
            return;
        }

        // przywracamy pierwotną tablicę
        forecasts = originalForecasts;

        // ponownie liczymy ciepłe dni
        coutOfWarmDays = forecasts.Count(forecast => forecast.TemperatureC > 15);
    }

    private class WeatherForecast
    {
        public DateOnly Date { get; set; }
        public int TemperatureC { get; set; }
        public string? Summary { get; set; }
        public int TemperatureF => 32 + (int)(TemperatureC / 0.5556);
    }
}